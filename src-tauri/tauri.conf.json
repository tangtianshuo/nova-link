{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Nova Link",
	"version": "0.1.0",
	"identifier": "com.nova.link",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:18080",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../dist"
	},
	"app": {
		"withGlobalTauri": false,
		"windows": [
			{
				"title": "Nova Link",
				"width": 400,
				"height": 500,
				"resizable": false,
				"fullscreen": false,
				"decorations": false,
				"transparent": true,
				"alwaysOnTop": true,
				"skipTaskbar": false,
				"shadow": false,
				"center": false,
				"x": 100,
				"y": 100
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
