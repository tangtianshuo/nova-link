{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Nova Link",
	"version": "0.0.11",
	"identifier": "com.nova.link",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:18080",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../dist"
	},
	"app": {
		"withGlobalTauri": false,
		"macOSPrivateApi": true,
		"windows": [
			{
				"title": "Nova Link",
				"label": "main",
				"width": 400,
				"height": 800,
				"resizable": true,
				"fullscreen": false,
				"decorations": false,
				"transparent": true,
				"alwaysOnTop": true,
				"skipTaskbar": false,
				"shadow": false,
				"center": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ0NzhEQkIzNENFNDM0RgpSV1JQUTg0MHU0MUhEWDZ5c3ZVN3pNNERGUHFGL1VoMUJzZTdXaDd6YjlFeVl1SEN1WGtRSU1HKwo=",
			"endpoints": [
				"https://github.com/tangtianshuo/nova-link/releases/latest/download/latest.json"
			],
			"windows": {
				"installMode": "passive"
			},
			"macOS": {
				"installMode": "download"
			}
		}
	},
	"bundle": {
		"active": true,
		"createUpdaterArtifacts": true,
		"targets": ["msi", "dmg"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico",
			"icons/icon.png"
		],
		"windows": {
			"wix": {
				"language": "zh-CN"
			}
		},
		"macOS": {
			"minimumSystemVersion": "10.15"
		},
		"category": "Utility",
		"shortDescription": "Nova Link - Live2D Desktop Assistant",
		"longDescription": "A desktop overlay application with Live2D character display"
	}
}
