{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Nova Link",
	"version": "0.1.0",
	"identifier": "com.nova.link",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:18080",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../dist"
	},
	"app": {
		"withGlobalTauri": false,
		"windows": [
			{
				"title": "Nova Link",
				"width": 500,
				"height": 600,
				"resizable": false,
				"fullscreen": false,
				"decorations": false,
				"transparent": true,
				"alwaysOnTop": true,
				"skipTaskbar": false,
				"shadow": true,
				"center": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": ["msi", "dmg"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico",
			"icons/icon.png"
		],
		"windows": {
			"wix": {
				"language": "zh-CN"
			}
		},
		"macOS": {
			"minimumSystemVersion": "10.15"
		},
		"category": "Utility",
		"shortDescription": "Nova Link - Live2D Desktop Assistant",
		"longDescription": "A desktop overlay application with Live2D character display and WebSocket connectivity"
	}
}
